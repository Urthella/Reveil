{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native|@react-navigation|expo(nent)?|@expo(nent)?|expo-modules-core|expo-asset|expo-font|expo-constants|expo-status-bar|expo-notifications|expo-device|@react-native-async-storage|@react-native-community/netinfo|firebase|@firebase)"
    ],
    "setupFiles": [
      "./jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.expo/"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "@sentry/browser": "^10.52.0",
    "axios": "^1.13.2",
    "expo": "~54.0.31",
    "expo-apple-authentication": "^55.0.13",
    "expo-auth-session": "^55.0.15",
    "expo-crypto": "^55.0.14",
    "expo-device": "~7.1.4",
    "expo-file-system": "^55.0.17",
    "expo-haptics": "^55.0.14",
    "expo-notifications": "^0.32.17",
    "expo-sharing": "^55.0.18",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "^55.0.15",
    "firebase": "^10.14.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
