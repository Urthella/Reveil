# Server
PORT=3000

# AI engine
AI_ENGINE_URL=http://127.0.0.1:8000

# Database — leave DB_DRIVER unset (defaults to sqlite) for dev
# DB_DRIVER=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=reveil
# DB_SYNC=true     # auto-create schema (dev only); set "false" in production and use migrations

# Weekly digest cron (set to "off" to disable)
# DIGEST_CRON=on

# Email digest (Resend) — optional. Both must be set to enable.
# RESEND_API_KEY=
# DIGEST_FROM_EMAIL=Reveil <noreply@reveil.app>

# Sentry (optional — leave empty to disable)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Firebase (leave empty to keep mock auth)
# FIREBASE_SERVICE_ACCOUNT='{"project_id":"...","client_email":"...","private_key":"..."}'
# FIREBASE_PROJECT_ID=
# Or set GOOGLE_APPLICATION_CREDENTIALS to a path
